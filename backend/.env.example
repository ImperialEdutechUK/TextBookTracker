# The connection params bound how long the app waits on the database so a slow
# or stalled query fails fast (and frees its connection) instead of hanging
# forever and exhausting the pool:
#   connect_timeout  - max seconds to establish a connection
#   pool_timeout     - max seconds to wait for a free pooled connection
#   socket_timeout   - max seconds for a single query before it errors out
#   connection_limit - max pooled connections (keep well under the DB's limit)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/textbooktracker?connection_limit=10&pool_timeout=20&connect_timeout=15&socket_timeout=60"
JWT_SECRET="replace-with-a-strong-secret"
PORT=4000
FRONTEND_URL="http://localhost:3000"
# Set to true only when frontend and backend are on different sites (requires HTTPS).
CROSS_SITE_COOKIES=false

# The single manager/admin login. Run `npm run seed` after setting these to
# create/update the account (re-running updates the password).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2026
ADMIN_FULLNAME=Administrator
