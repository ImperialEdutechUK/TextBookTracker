generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           BigInt   @id @default(autoincrement())
  fullName     String
  email        String   @unique
  // Null for Learner/Viewer accounts, which have no login. Every other role
  // stores a bcrypt hash here.
  passwordHash String?
  role         Role     @default(CREATOR)
  status       Status   @default(ACTIVE)
  // Contact number and address are only collected/stored for Learner/Viewer
  // accounts; other roles leave them null.
  contactNumber String? @map("contact_number")
  address       String? @map("address")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Back-relations owned by the Textbook Management module. These are virtual
  // (no columns added to the User table), so they do not alter the auth module.
  createdRequests TextbookRequest[]       @relation("RequestCreator")
  learnerRequests TextbookRequest[]       @relation("RequestLearner")
  statusChanges   TextbookStatusHistory[]
}

enum Role {
  ADMIN
  CREATOR
  MANAGER
  VIEWER
}

enum Status {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ---------------------------------------------------------------------------
// Textbook Management module
// ---------------------------------------------------------------------------

// Lifecycle of a textbook request. Status *transitions* are owned by the
// Workflow / Status Tracking module; this module only sets the initial CREATED
// state and renders the history.
enum TextbookStatus {
  CREATED
  REQUESTED_BY_LEARNER
  SHARED_WITH_MANAGER
  SENT_TO_PRINT
  PRINTED
}

// Available textbook catalog.
model Textbook {
  id           BigInt   @id @default(autoincrement()) @map("textbook_id")
  textbookName String   @map("textbook_name")
  subject      String?
  // Uploaded PDF. The raw bytes are stored in the database (BYTEA) so the file
  // is available to every backend instance and survives ephemeral filesystems;
  // originalName/size/type are kept for download headers and listing.
  fileData     Bytes?   @map("file_data")
  originalName String?  @map("original_name")
  fileSize     BigInt?  @map("file_size")
  mimeType     String?  @map("mime_type")
  // Small JPEG of the PDF's first page, rendered in the browser at upload time.
  // Served to the catalog grid so cards never download the whole PDF for a cover.
  coverImage    Bytes?  @map("cover_image")
  coverMimeType String? @map("cover_mime_type")
  createdAt    DateTime @default(now()) @map("created_at")

  requests TextbookRequest[]

  @@map("textbooks")
}

model TextbookRequest {
  id            BigInt         @id @default(autoincrement()) @map("request_id")
  learnerId     BigInt         @map("learner_id")
  textbookId    BigInt         @map("textbook_id")
  creatorId     BigInt         @map("creator_id")
  currentStatus TextbookStatus @default(CREATED) @map("current_status")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  learner       User                    @relation("RequestLearner", fields: [learnerId], references: [id])
  creator       User                    @relation("RequestCreator", fields: [creatorId], references: [id])
  textbook      Textbook                @relation(fields: [textbookId], references: [id])
  statusHistory TextbookStatusHistory[]

  @@index([learnerId])
  @@index([creatorId])
  @@index([textbookId])
  @@index([currentStatus])
  @@map("textbook_requests")
}

model TextbookStatusHistory {
  id        BigInt         @id @default(autoincrement()) @map("history_id")
  requestId BigInt         @map("request_id")
  status    TextbookStatus
  changedBy BigInt         @map("changed_by")
  changedAt DateTime       @default(now()) @map("changed_at")

  request       TextbookRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  changedByUser User            @relation(fields: [changedBy], references: [id])

  @@index([requestId])
  @@map("textbook_status_history")
}
