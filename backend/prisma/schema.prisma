generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id           BigInt   @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @default("Administrator") @map("full_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@map("users")
}
enum RequestStatus {
  RECEIVED
  SENT_TO_PRINT
  PRINTED
}
enum RequestEventType {
  CREATED
  PDF_ATTACHED
  PDF_REMOVED
  SENT_TO_PRINT
  PRINTED
  REVERTED
}
model TextbookRequest {
  id             BigInt        @id @default(autoincrement()) @map("request_id")
  fullName       String        @map("full_name")
  firstName      String?       @map("first_name")
  lastName       String?       @map("last_name")
  email          String
  contactNumber  String        @map("contact_number")
  course         String
  units          String
  address        String
  status         RequestStatus @default(RECEIVED)
  trackingNumber String?       @map("tracking_number")

  // Slot 1 (original)
  bookName1    String? @map("book_name_1")
  fileName     String? @map("file_name")
  originalName String? @map("original_name")
  fileSize     BigInt? @map("file_size")
  mimeType     String? @map("mime_type")
  fileData     Bytes?  @map("file_data")

  // Slot 2
  bookName2     String? @map("book_name_2")
  fileName2     String? @map("file_name_2")
  originalName2 String? @map("original_name_2")
  fileSize2     BigInt? @map("file_size_2")
  mimeType2     String? @map("mime_type_2")
  fileData2     Bytes?  @map("file_data_2")

  // Slot 3
  bookName3     String? @map("book_name_3")
  fileName3     String? @map("file_name_3")
  originalName3 String? @map("original_name_3")
  fileSize3     BigInt? @map("file_size_3")
  mimeType3     String? @map("mime_type_3")
  fileData3     Bytes?  @map("file_data_3")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  events RequestEvent[]

  @@index([status])
  @@map("textbook_requests")
}
model RequestEvent {
  id        BigInt           @id @default(autoincrement()) @map("event_id")
  requestId BigInt           @map("request_id")
  type      RequestEventType
  detail    String?
  createdAt DateTime         @default(now()) @map("created_at")
  request TextbookRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  @@index([requestId])
  @@map("request_events")
}
