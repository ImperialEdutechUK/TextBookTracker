generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Single manager/admin account. There are no roles — one login does everything
// (enter the request, send to print with the tracking number, mark it printed).
model User {
  id           BigInt   @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @default("Administrator") @map("full_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// Request lifecycle: RECEIVED -> SENT_TO_PRINT -> PRINTED. Each request can move
// one step forward or one step back (revert).
enum RequestStatus {
  RECEIVED
  SENT_TO_PRINT
  PRINTED
}

// Time-stamped audit entries for a request, used to build the activity timeline
// (request created, PDF attached, sent to print, printed, reverted).
enum RequestEventType {
  CREATED
  PDF_ATTACHED
  PDF_REMOVED
  SENT_TO_PRINT
  PRINTED
  REVERTED
}

// A learner's textbook request. The learner's details are entered directly from
// their request email, so they are stored inline on the request rather than as a
// separate user/textbook record.
model TextbookRequest {
  id             BigInt        @id @default(autoincrement()) @map("request_id")
  fullName       String        @map("full_name")
  firstName      String?       @map("first_name")
  lastName       String?       @map("last_name")
  email          String
  contactNumber  String        @map("contact_number")
  course         String
  units          String
  address        String
  status         RequestStatus @default(RECEIVED)
  trackingNumber String?       @map("tracking_number")

  // Attached PDF (the printed textbook). Bytes live in the DB so they survive
  // redeploys on hosts with an ephemeral filesystem.
  fileName     String? @map("file_name")
  originalName String? @map("original_name")
  fileSize     BigInt? @map("file_size")
  mimeType     String? @map("mime_type")
  fileData     Bytes?  @map("file_data")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  events RequestEvent[]

  @@index([status])
  @@map("textbook_requests")
}

model RequestEvent {
  id        BigInt           @id @default(autoincrement()) @map("event_id")
  requestId BigInt           @map("request_id")
  type      RequestEventType
  detail    String?
  createdAt DateTime         @default(now()) @map("created_at")

  request TextbookRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("request_events")
}
